{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "pnpm install --frozen-lockfile && pnpm --filter @workspace/dobierzmibilet run build"
  },
  "deploy": {
    "startCommand": "npx serve -s artifacts/dobierzmibilet/dist/public -l $PORT",
    "healthcheckPath": "/",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}